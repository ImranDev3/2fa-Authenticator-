{
  "name": "crypto-core",
  "version": "1.0.0",
  "description": "AssemblyScript crypto core - SHA-256, AES-256-GCM, Argon2id → WASM",
  "main": "build/crypto-core.js",
  "scripts": {
    "build": "npx asc assembly/index.ts --outFile build/crypto-core.wasm --exportRuntime --optimize --enable simd",
    "build:debug": "npx asc assembly/index.ts --outFile build/crypto-core.wasm --exportRuntime --debug"
  },
  "devDependencies": {
    "assemblyscript": "^0.27.0"
  }
}
